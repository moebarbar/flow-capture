{
  "manifest_version": 3,
  "name": "FlowCapture",
  "version": "1.0.0",
  "description": "Capture browser workflows and create step-by-step guides automatically",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "*://*.replit.dev/*",
      "*://*.replit.app/*",
      "*://*.repl.co/*",
      "*://localhost:*/*",
      "*://127.0.0.1:*/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["messaging.js", "selector.js", "screenshot.js", "overlay.js", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
