{
  "manifest_version": 3,
  "name": "FlowCapture - Workflow Documentation",
  "version": "1.0.1",
  "description": "Automatically capture browser interactions and create step-by-step workflow guides with screenshots. Perfect for training, onboarding, and documentation.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "sidePanel",
    "notifications"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FlowCapture - Capture a new workflow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.replit.app/*",
        "https://*.replit.dev/*",
        "https://*.repl.co/*",
        "http://localhost:5000/*",
        "http://127.0.0.1:5000/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/highlight.css", "src/content.js", "src/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
